# Required
OPENAI_API_KEY=sk-...

# Public URL of the API server — used by the frontend at build time.
# Set this to your server's public hostname/IP when deploying (e.g. https://crr.example.com).
# Defaults to http://localhost:8000 for local dev.
# NEXT_PUBLIC_API_URL=https://your-server.com

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Optional – Qdrant collection name (default: eu_crr). Override to target a different collection
# for A/B experiments (e.g. eu_crr_v2) without touching code.
# QDRANT_COLLECTION=eu_crr

# Optional – enables LlamaParse as primary HTML parser
LLAMA_CLOUD_API_KEY=llx-...

# Optional – Gemini API key for dataset review (evals/review_dataset.py --provider gemini)
# Using Gemini as reviewer avoids correlated blind-spots with the OpenAI-generated dataset.
# Get a key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# Optional – LLM model for synthesis (default gpt-4o-mini; set to gpt-4o for higher quality)
# OPENAI_MODEL=gpt-4o-mini

# Optional – enable BGE-Reranker-v2-m3 at query time (requires ~550MB extra RAM; default false)
# Set to true on GPU machines (Colab T4, cloud instances); leave unset for local dev
USE_RERANKER=false

# Optional – cross-encoder reranker model.
# Current best (run_31): BAAI/bge-reranker-v2-m3 — multilingual, legal-domain aware, ~560MB.
# Prior best (run_2): cross-encoder/ms-marco-MiniLM-L-6-v2 — fast, English-only, ~22MB.
# 12-layer variant (run_13, regression): cross-encoder/ms-marco-MiniLM-L-12-v2
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Optional – hybrid fusion weight (0.0=sparse, 1.0=dense, default 0.5). Tune with golden dataset.
# RETRIEVAL_ALPHA=0.5

# Optional – article title boost weight (0=disabled, default 0.15). Additive bonus when query
# tokens overlap with article title; improves recall for open-ended vocabulary-gap queries.
# TITLE_BOOST_WEIGHT=0.15

# Optional – LLM pre-retrieval query enrichment (default true). When true, GPT-4o-mini predicts
# relevant CRR article numbers for open-ended queries and appends them as search hints.
# Adds ~1-2s latency per open-ended query. Set to false for a clean baseline or to save cost.
# USE_QUERY_ENRICHMENT=true

# Optional – domain query rewriting (default false). When true, GPT-4o-mini rewrites the
# plain-language query into precise CRR legal register before embedding (e.g. "pledged bonds"
# → "encumbered assets", "total risk exposure" → "total risk exposure amount (TREA)"). Unlike
# HyDE, this produces a concise rewritten question rather than a hypothetical passage, targeting
# terminology dilution failures where the query shares few tokens with the article text.
# Mutually exclusive with USE_HYDE and USE_QUERY_ENRICHMENT (domain rewrite takes precedence).
# Adds ~1s latency per open-ended query.
# USE_DOMAIN_QUERY_REWRITE=false

# Optional – true HyDE (Hypothetical Document Embedding, default false). When true, GPT-4o-mini
# generates a hypothetical CRR-style passage in formal legislative language to use as the
# retrieval query instead of the plain-language question. Targets terminology dilution failures
# where the query vocabulary has no overlap with article text. Mutually exclusive with
# USE_QUERY_ENRICHMENT and USE_DOMAIN_QUERY_REWRITE (domain rewrite takes precedence when set).
# USE_HYDE=false

# Optional – enable ToC-guided LLM routing (default false). When true, GPT-4o-mini reasons
# over the full CRR Table of Contents to predict relevant articles. Fires only when the
# post-retrieval max reranker score falls below TOC_CONFIDENCE_THRESHOLD (post-retrieval gating),
# so high-confidence queries pay zero latency overhead. Requires CRR_ToC.html in project root.
# USE_TOC_ROUTING=false

# Optional – reranker score threshold below which ToC routing activates (default 0.55).
# Only relevant when USE_TOC_ROUTING=true. Lower values = fewer ToC calls; higher = more.
# TOC_CONFIDENCE_THRESHOLD=0.55

# Optional – server-side query timeout in seconds (default 150). Raise for complex multi-hop
# queries on slow hardware; lower to free worker threads faster under load.
# Must match the --timeout flag passed to evals/run_eval.py.
# QUERY_TIMEOUT_SECONDS=150

# Optional – adjacent article tiebreaker score delta (default 0.0 = disabled). When top-2
# retrieved nodes are adjacent articles (same numeric base or consecutive) and their score
# gap is below this threshold, prefers the article whose title overlaps the query more.
# Targets false-friend rank-flip failures. Recommended starting value: 0.05.
# ADJACENT_TIEBREAK_DELTA=0.0

# Optional – paragraph-window reranker (default false). When true, the cross-encoder scores
# each article by its *best-matching paragraph window* rather than the full article text.
# Targets false_friend and long-article dilution failures. Replaces the standard reranker.
# USE_PARAGRAPH_WINDOW_RERANKER=false

# Optional – max paragraph windows scored per article by ParagraphWindowReranker (default 4).
# Higher values improve accuracy but increase latency linearly. Recommended range: 3–6.
# PARAGRAPH_WINDOW_MAX_WINDOWS=4

# Optional – BGE-M3 INT8 dynamic quantization (default false, run_33 experiment).
# When true, applies torch.quantization.quantize_dynamic to all nn.Linear layers in the
# BGE-M3 encoder at startup.  Gives ~2–4x faster CPU inference with near-zero accuracy loss.
# use_fp16=True is a no-op on CPU so the model is FP32 before quantization.
# BGE_M3_INT8=false

# Optional – embedding model (default: bge-m3). Switch to e5-large-instruct for run_29
# (instruction-tuned, better semantic recall for plain-language queries; dense-only, no hybrid).
# Requires re-ingest into a separate collection (e.g. QDRANT_COLLECTION=eu_crr_e5).
# EMBED_MODEL=bge-m3

# Optional – blend direct article lookup with semantic retrieval via RRF (default true).
# When true, queries that cite exactly one article but ask about a related concept are not
# hard-anchored to that article alone — both the direct fetch and semantic retrieval are run
# and merged. Set to false to restore the old hard-anchor behaviour for ablation testing.
# USE_BLENDED_DIRECT_RETRIEVAL=true

# Optional – structural sibling expansion for multi-article queries (default true).
# When true, articles in the same Section (or Chapter) as the top retrieved articles are
# appended as expansion candidates for multi-article queries. Budget-capped at 3 extra articles.
# Set to false to disable for ablation testing.
# USE_STRUCTURAL_SIBLINGS=true

# Optional – reverse-edge graph expansion (default true).
# When true, a reverse BFS (articles that cite the seed articles) is run alongside the forward
# BFS with a budget of 2. Surfaces procedural companion articles like Art 414 from seed Art 413.
# Set to false to disable for ablation testing.
# USE_REVERSE_GRAPH_EXPANSION=true

# Optional – global re-rank of primary and expanded nodes together (default true).
# When true, the primary retrieval nodes and expanded nodes are merged and re-ranked globally
# by the active reranker so that a highly-relevant expanded node can reach rank-1.
# Without this, expansion improves recall/context but cannot change hit@1.
# Set to false to restore the old append behaviour for ablation testing.
# USE_GLOBAL_RERANK=true

# Optional – paragraph-level chunking (default false). When true, the index must have been
# ingested with paragraph chunks (ARTICLE + PARAGRAPH docs per article). Retrieval filters
# to PARAGRAPH chunks; context assembly fetches parent ARTICLE docs for synthesis.
# USE_PARAGRAPH_WINDOW_RERANKER=true is redundant with this and auto-falls back to BlendedReranker.
# USE_PARAGRAPH_CHUNKING=false
# Mixed mode: both ARTICLE and PARAGRAPH chunks compete in retrieval. An ArticleDeduplicatorPostprocessor
# keeps the best-scored chunk per article; any winning PARAGRAPH chunk is upgraded to parent ARTICLE text.
# USE_MIXED_CHUNKING=false
