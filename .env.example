# Required
OPENAI_API_KEY=sk-...

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Optional – enables LlamaParse as primary HTML parser
LLAMA_CLOUD_API_KEY=llx-...

# Optional – enable BGE-Reranker-v2-m3 at query time (requires ~550MB extra RAM; default false)
# Set to true on GPU machines (Colab T4, cloud instances); leave unset for local dev
USE_RERANKER=false

# Optional – hybrid fusion weight (0.0=sparse, 1.0=dense, default 0.5). Tune with golden dataset.
# RETRIEVAL_ALPHA=0.5
